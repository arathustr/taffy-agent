{
  "name": "taffy-agent",
  "version": "0.1.0",
  "description": "Graphical computer-use agent terminal for Codex, browser, shell, file, and DeepSeek workflows.",
  "main": "dist-electron/index.cjs",
  "author": "Taffy Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arathustr/taffy-agent.git"
  },
  "bugs": {
    "url": "https://github.com/arathustr/taffy-agent/issues"
  },
  "homepage": "https://github.com/arathustr/taffy-agent#readme",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:main && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:main": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist-electron/index.cjs --external:electron --external:sharp && esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "build": "npm run typecheck && vite build && npm run build:main",
    "preview": "vite preview --host 127.0.0.1",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "voice:prepare": "python scripts/prepare-gptsovits-dataset.py",
    "voice:start": "pwsh -ExecutionPolicy Bypass -File scripts/start-gptsovits-api.ps1",
    "package": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "fan.taffy.agent",
    "productName": "Taffy Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/@img/**/*",
      "node_modules/detect-libc/**/*",
      "node_modules/semver/**/*",
      "node_modules/sharp/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "target": [
        "nsis"
      ]
    }
  }
}
